{
  "name": "@pampalo/shared",
  "version": "0.1.0",
  "type": "module",
  "description": "Pampalo protocol cryptography: notes, ZK proofs, ECIES note encryption, Poseidon merkle tree.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pampalodotcom/pampalo.git",
    "directory": "shared"
  },
  "exports": {
    "./classes/*": "./classes/*.ts",
    "./constants/*": "./constants/*.ts",
    "./types/*": "./types/*.ts"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "exports": {
      "./classes/*": {
        "types": "./dist/classes/*.d.ts",
        "default": "./dist/classes/*.js"
      },
      "./constants/*": {
        "types": "./dist/constants/*.d.ts",
        "default": "./dist/constants/*.js"
      },
      "./types/*": {
        "types": "./dist/types/*.d.ts",
        "default": "./dist/types/*.js"
      }
    }
  },
  "scripts": {
    "tsc": "tsc --noEmit",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && cp -r circuits dist/circuits",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@aztec/bb.js": "5.0.0-nightly.20260324",
    "@noir-lang/noir_js": "1.0.0-beta.21",
    "@zkpassport/poseidon2": "^0.6.2",
    "eciesjs": "^0.4.16",
    "ethers": "^6.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "~5.8.3"
  }
}
